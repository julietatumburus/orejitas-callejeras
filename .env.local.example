# Copiá este archivo como ".env.local" y completá con los datos reales.

# --- Supabase (Project Settings → Data API / API Keys) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-public-key

# --- Resend (envío de mails) — SECRETO, nunca con prefijo NEXT_PUBLIC_ ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Remitente verificado en Resend (o usá onboarding@resend.dev para pruebas)
RESEND_FROM="Orejitas Callejeras <no-reply@tudominio.com>"

# Clave del servidor de Supabase para crear usuarios desde el backend (Settings → API Keys → service_role / secret)
# SECRETO. Necesaria para el flujo de alta de usuarios con clave temporal.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-o-sb_secret_key

# URL pública del sitio (para el botón "Ingresar" de los mails). En Vercel: tu dominio.
NEXT_PUBLIC_APP_URL=https://orejitas-callejeras.vercel.app
